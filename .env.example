NODE_ENV=development
PORT=5000

# Development: localhost origins. Wildcards are supported for ports.
CORS_ALLOWED_ORIGINS_DEV=http://localhost:*,http://127.0.0.1:*

# Production: comma-separated origins. Wildcard subdomains are supported.
CORS_ALLOWED_ORIGINS=https://*.sandeep.cv

# Optional: protect /api/q and /api/quick with a token.
# Send it with: -H "x-quick-token: your-secret-token" or ?key=your-secret-token
QUICK_SEND_TOKEN=
QUICK_SEND_RATE_LIMIT=3
